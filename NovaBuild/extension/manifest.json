{
  "manifest_version": 3,
  "name": "NovaBuild",
  "version": "1.1.0",
  "description": "AI-powered build studio — connect DeepSeek, ChatGPT, or Arena.ai and build websites, games, and more.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://chat.deepseek.com/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://arena.ai/*",
    "https://lmarena.ai/*",
    "http://127.0.0.1/*",
    "http://localhost/*",
    "http://127.0.0.1:17614/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "studio/studio.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.deepseek.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://arena.ai/*",
        "https://lmarena.ai/*"
      ],
      "js": ["content/ai-connector.js"],
      "css": ["content/ai-overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/injected-panel.html", "studio/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
